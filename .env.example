# MetaGPT + E2B Integration System — Environment Configuration

# Core Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change_this_in_production

# Security
CORS_ORIGINS=*

# AWS Configuration (required for Bedrock)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# Bedrock Configuration
BEDROCK_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# MetaGPT — REQUIRED for /generate: set ONE direct API key (OpenAI or Anthropic).
# Bedrock (above) is separate; MetaGPT agents do not run on Bedrock-only config.
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
METAGPT_WORKSPACE=./workspace

# E2B Sandbox (required for live code execution)
E2B_API_KEY=your_e2b_api_key_here
E2B_TEMPLATE_ID=base
E2B_TIMEOUT=1800
E2B_CPU_LIMIT=2
E2B_MEMORY_LIMIT=2048

# Session Management
SESSION_TIMEOUT=7200
MAX_CONCURRENT_SESSIONS=10

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Feature Flags
ENABLE_E2B=true
ENABLE_BEDROCK=true
